# -*- mode: ruby -*-
# vi: set ft=ruby :

## configuration variables ##
# max number of worker nodes (w1~w3 + aggregator w4)
N = 4
# each of components to install (must match the running cluster)
k8s_V    = '1.36.1-1.1'                   # Kubernetes
ctrd_V   = '2.2.3-1~ubuntu.24.04~noble'  # Containerd
## /configuration variables ##

# 7.5.3 정제(aggregator) 확장 구성: 기본 클러스터(7.1.1)의 cp/w1~w3에 정제 전용
# 워커 w4-k8s(4코어/16GB)를 더한 형태다. 이미 기동 중인 클러스터에는
# `vagrant up w4-k8s-1.36.1` 로 w4만 추가 기동해 무중단 조인한다(조인 토큰 ttl 0).
# cp/w1~w3 정의는 7.1.1과 같은 VM 이름을 쓰므로 기존 클러스터가 떠 있는 동안
# 인자 없는 `vagrant up` 은 이름 충돌로 실패한다 — w4 단독 기동 용도로만 쓴다.

Vagrant.configure("2") do |config|

  #====================#
  # Control-Plane Node #
  #====================#

    config.vm.define "cp-k8s-#{k8s_V[0..5]}" do |cfg|
      cfg.vm.box = "sysnet4admin/Ubuntu-k8s"
      cfg.vm.provider "virtualbox" do |vb|
        vb.name = "cp-k8s-#{k8s_V[0..5]}(github_SysNet4Admin)"
        vb.cpus = 2
        vb.memory = 2560
        vb.customize ["modifyvm", :id, "--groups", "/Book-k8s-ludus-U#{k8s_V[0..5]}-ctrd-#{ctrd_V[0..2]}(github_SysNet4Admin)"]
      end
      cfg.vm.host_name = "cp-k8s"
      cfg.vm.network "private_network", ip: "192.168.1.10"
      cfg.vm.network "forwarded_port", guest: 22, host: 60010, auto_correct: true, id: "ssh"
      cfg.vm.synced_folder "../../data", "/vagrant", disabled: true
      cfg.vm.provision "shell", path: "../../7.1.1/k8s_env_build.sh", args: [ N, k8s_V[0..3] ]
      cfg.vm.provision "shell", path: "../../7.1.1/k8s_pkg_cfg.sh", args: [ k8s_V, ctrd_V, "CP"]
      cfg.vm.provision "shell", path: "../../7.1.1/controlplane_node.sh"
      cfg.vm.provision "shell", path: "../../7.1.1/extra_k8s_pkgs.sh"
    end

  #==============#
  # Worker Nodes #
  #==============#

  (1..N).each do |i|
    config.vm.define "w#{i}-k8s-#{k8s_V[0..5]}" do |cfg|
      cfg.vm.box = "sysnet4admin/Ubuntu-k8s"
      cfg.vm.provider "virtualbox" do |vb|
        vb.name = "w#{i}-k8s-#{k8s_V[0..5]}(github_SysNet4Admin)"
        if i == 4   # 정제(aggregator) 전용 워커: 12b급 모델 상주를 위해 증설
          vb.cpus = 4
          vb.memory = 16384
        else
          vb.cpus = 2
          vb.memory = 3584
        end
        vb.customize ["modifyvm", :id, "--groups", "/Book-k8s-ludus-U#{k8s_V[0..5]}-ctrd-#{ctrd_V[0..2]}(github_SysNet4Admin)"]
      end
      cfg.vm.host_name = "w#{i}-k8s"
      cfg.vm.network "private_network", ip: "192.168.1.10#{i}"
      cfg.vm.network "forwarded_port", guest: 22, host: "6010#{i}", auto_correct: true, id: "ssh"
      cfg.vm.synced_folder "../../data", "/vagrant", disabled: true
      cfg.vm.provision "shell", path: "../../7.1.1/k8s_env_build.sh", args: [ N, k8s_V[0..3] ]
      cfg.vm.provision "shell", path: "../../7.1.1/k8s_pkg_cfg.sh", args: [ k8s_V, ctrd_V, "W" ]
      cfg.vm.provision "shell", path: "../../7.1.1/worker_nodes.sh"
    end
  end

end
